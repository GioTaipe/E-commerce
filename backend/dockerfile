FROM node:20-slim AS base

# Instalar dependencias (incluyendo dev para compilar TS)
FROM base AS deps
WORKDIR /app
COPY package*.json ./
RUN npm ci

# Compilar TypeScript
FROM deps AS builder
WORKDIR /app
COPY . .
RUN npx prisma generate
RUN npm run build

# Imagen de producción (solo dependencias de producción)
FROM base AS runner
WORKDIR /app

ENV NODE_ENV=production

COPY package*.json ./
RUN npm ci --omit=dev

COPY --from=builder /app/dist ./dist
COPY --from=builder /app/node_modules/.prisma ./node_modules/.prisma
COPY --from=builder /app/prisma ./prisma

EXPOSE 3000

CMD ["node", "dist/server.js"]
